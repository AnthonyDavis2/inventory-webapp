{
  "name": "inventory-app",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:migrate": "pnpm --filter backend exec prisma migrate dev",
    "db:migrate:prod": "pnpm --filter backend exec prisma migrate deploy",
    "db:seed": "pnpm --filter backend exec prisma db seed",
    "db:studio": "pnpm --filter backend exec prisma studio",
    "db:generate": "pnpm --filter backend exec prisma generate"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
