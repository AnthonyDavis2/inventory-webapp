// ============================================================
// Business Operations Platform — Prisma Schema
// Version: 1.0 (MVP)
// Last updated: 2026-06-24
//
// Rules:
//   - All monetary values: BIGINT (integer cents)
//   - All IDs: UUID
//   - All timestamps: TIMESTAMPTZ (UTC)
//   - All business tables: include org_id
//   - All business tables: soft delete (deleted_at)
//   - All enums: defined as Prisma enums
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// PLATFORM — Organizations, Users, Auth, Billing
// ============================================================

model Organization {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String
  slug                String    @unique
  email               String
  phone               String?
  website             String?
  address_line1       String?
  address_line2       String?
  city                String?
  state               String?   @db.Char(2)
  zip                 String?
  country             String    @default("US") @db.Char(2)
  logo_url            String?
  timezone            String    @default("America/New_York")
  fiscal_year_start   Int       @default(1) // 1 = January
  costing_method      CostingMethod?
  costing_locked      Boolean   @default(false) // locked after first ledger entry
  currency_code       String    @default("USD") @db.VarChar(3)
  onboarding_step     Int       @default(0) // 0–7
  onboarding_complete Boolean   @default(false)
  is_read_only        Boolean   @default(false) // trial expired or payment failed
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz
  deleted_at          DateTime? @db.Timestamptz

  users               User[]
  subscription        Subscription?
  warehouses          Warehouse[]
  uoms                UnitOfMeasure[]
  uom_conversions     UOMConversion[]
  product_categories  ProductCategory[]
  products            Product[]
  inventory_ledger    InventoryLedgerEntry[]
  fifo_cost_layers    FifoCostLayer[]
  wac_costs           WeightedAverageCost[]
  lots                Lot[]
  serial_numbers      SerialNumber[]
  reorder_rules       ReorderRule[]
  vendors             Vendor[]
  purchase_orders     PurchaseOrder[]
  customers           Customer[]
  customer_groups     CustomerGroup[]
  price_lists         PriceList[]
  quotes              Quote[]
  sales_orders        SalesOrder[]
  invoices            Invoice[]
  return_auths        ReturnAuthorization[]
  boms                BillOfMaterials[]
  work_orders         WorkOrder[]
  overhead_rule       OverheadAllocationRule?
  product_costs       ProductStandardCost[]
  chart_of_accounts   ChartOfAccount[]
  journal_entries     JournalEntry[]
  expenses            Expense[]
  expense_categories  ExpenseCategory[]
  tax_settings        TaxSettings?
  notifications       Notification[]
  import_batches      ImportBatch[]
  audit_logs          AuditLog[]

  @@index([slug])
  @@map("organizations")
}

model User {
  id                  String    @id @default(uuid()) @db.Uuid
  org_id              String    @db.Uuid
  email               String
  name                String
  password_hash       String
  role                UserRole
  is_active           Boolean   @default(true)
  mfa_enabled         Boolean   @default(false)
  mfa_secret          String?   // encrypted at application layer
  mfa_backup_codes    String[]  // encrypted
  password_history    String[]  // last 5 bcrypt hashes
  last_login_at       DateTime? @db.Timestamptz
  invited_by          String?   @db.Uuid
  invitation_token    String?
  invitation_expires  DateTime? @db.Timestamptz
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz
  deleted_at          DateTime? @db.Timestamptz

  org                 Organization @relation(fields: [org_id], references: [id])
  sessions            UserSession[]
  notification_prefs  NotificationPreference[]

  @@unique([org_id, email])
  @@index([org_id])
  @@index([email])
  @@index([invitation_token])
  @@map("users")
}

model UserSession {
  id                  String    @id @default(uuid()) @db.Uuid
  user_id             String    @db.Uuid
  refresh_token_hash  String    @unique
  ip_address          String?
  user_agent          String?
  expires_at          DateTime  @db.Timestamptz
  revoked_at          DateTime? @db.Timestamptz
  created_at          DateTime  @default(now()) @db.Timestamptz

  user                User      @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([refresh_token_hash])
  @@map("user_sessions")
}

model Subscription {
  id                    String             @id @default(uuid()) @db.Uuid
  org_id                String             @unique @db.Uuid
  stripe_customer_id    String             @unique
  stripe_subscription_id String?           @unique
  plan                  SubscriptionPlan
  status                SubscriptionStatus
  trial_ends_at         DateTime?          @db.Timestamptz
  current_period_start  DateTime?          @db.Timestamptz
  current_period_end    DateTime?          @db.Timestamptz
  cancel_at_period_end  Boolean            @default(false)
  cancelled_at          DateTime?          @db.Timestamptz
  created_at            DateTime           @default(now()) @db.Timestamptz
  updated_at            DateTime           @updatedAt @db.Timestamptz

  org                   Organization       @relation(fields: [org_id], references: [id])

  @@index([stripe_customer_id])
  @@index([stripe_subscription_id])
  @@map("subscriptions")
}

// ============================================================
// UNITS OF MEASURE
// ============================================================

model UnitOfMeasure {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String?   @db.Uuid  // null = global library entry
  name            String
  abbreviation    String
  type            UOMType
  is_global       Boolean   @default(false)
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  org             Organization?  @relation(fields: [org_id], references: [id])
  conversions_from UOMConversion[] @relation("FromUOM")
  conversions_to   UOMConversion[] @relation("ToUOM")
  products_purchase Product[]     @relation("PurchaseUOM")
  products_stocking Product[]     @relation("StockingUOM")
  products_sales    Product[]     @relation("SalesUOM")
  bom_lines         BOMLine[]

  @@unique([org_id, abbreviation])
  @@index([org_id])
  @@map("units_of_measure")
}

model UOMConversion {
  id                  String    @id @default(uuid()) @db.Uuid
  org_id              String    @db.Uuid
  from_uom_id         String    @db.Uuid
  to_uom_id           String    @db.Uuid
  conversion_factor   Decimal   @db.Decimal(18, 8)
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz

  org                 Organization @relation(fields: [org_id], references: [id])
  from_uom            UnitOfMeasure @relation("FromUOM", fields: [from_uom_id], references: [id])
  to_uom              UnitOfMeasure @relation("ToUOM", fields: [to_uom_id], references: [id])

  @@unique([org_id, from_uom_id, to_uom_id])
  @@index([org_id])
  @@map("uom_conversions")
}

// ============================================================
// WAREHOUSES & LOCATIONS
// ============================================================

model Warehouse {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String    @db.Uuid
  name            String
  code            String
  address_line1   String?
  address_line2   String?
  city            String?
  state           String?   @db.Char(2)
  zip             String?
  is_default      Boolean   @default(false)
  bins_enabled    Boolean   @default(false)
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  created_by      String?   @db.Uuid
  updated_by      String?   @db.Uuid
  deleted_at      DateTime? @db.Timestamptz
  deleted_by      String?   @db.Uuid

  org             Organization @relation(fields: [org_id], references: [id])
  bin_locations   BinLocation[]
  ledger_entries  InventoryLedgerEntry[]
  fifo_layers     FifoCostLayer[]
  wac_costs       WeightedAverageCost[]
  reorder_rules   ReorderRule[]

  @@unique([org_id, code])
  @@index([org_id])
  @@map("warehouses")
}

model BinLocation {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String    @db.Uuid
  warehouse_id    String    @db.Uuid
  code            String    // e.g. A1-02-03
  description     String?
  is_active       Boolean   @default(true)
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  warehouse       Warehouse @relation(fields: [warehouse_id], references: [id])
  ledger_entries  InventoryLedgerEntry[]

  @@unique([warehouse_id, code])
  @@index([org_id])
  @@index([warehouse_id])
  @@map("bin_locations")
}

// ============================================================
// PRODUCTS & CATALOG
// ============================================================

model ProductCategory {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String    @db.Uuid
  parent_id       String?   @db.Uuid
  name            String
  description     String?
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  org             Organization    @relation(fields: [org_id], references: [id])
  parent          ProductCategory? @relation("CategoryTree", fields: [parent_id], references: [id])
  children        ProductCategory[] @relation("CategoryTree")
  products        Product[]

  @@index([org_id])
  @@index([parent_id])
  @@map("product_categories")
}

model Product {
  id                  String      @id @default(uuid()) @db.Uuid
  org_id              String      @db.Uuid
  sku                 String
  name                String
  description         String?
  type                ProductType
  category_id         String?     @db.Uuid
  purchase_uom_id     String      @db.Uuid
  stocking_uom_id     String      @db.Uuid
  sales_uom_id        String      @db.Uuid
  is_lot_tracked      Boolean     @default(false)
  is_serial_tracked   Boolean     @default(false)
  has_expiry          Boolean     @default(false)
  expiry_alert_days   Int?        // days before expiry to alert
  is_purchasable      Boolean     @default(true)
  is_sellable         Boolean     @default(true)
  is_manufactured     Boolean     @default(false)
  notes               String?
  currency_code       String      @default("USD") @db.VarChar(3)
  created_at          DateTime    @default(now()) @db.Timestamptz
  updated_at          DateTime    @updatedAt @db.Timestamptz
  created_by          String?     @db.Uuid
  updated_by          String?     @db.Uuid
  deleted_at          DateTime?   @db.Timestamptz
  deleted_by          String?     @db.Uuid

  org                 Organization   @relation(fields: [org_id], references: [id])
  category            ProductCategory? @relation(fields: [category_id], references: [id])
  purchase_uom        UnitOfMeasure  @relation("PurchaseUOM", fields: [purchase_uom_id], references: [id])
  stocking_uom        UnitOfMeasure  @relation("StockingUOM", fields: [stocking_uom_id], references: [id])
  sales_uom           UnitOfMeasure  @relation("SalesUOM", fields: [sales_uom_id], references: [id])
  variants            ProductVariant[]
  barcodes            ProductBarcode[]
  images              ProductImage[]
  ledger_entries      InventoryLedgerEntry[]
  fifo_layers         FifoCostLayer[]
  wac_costs           WeightedAverageCost[]
  lots                Lot[]
  serial_numbers      SerialNumber[]
  reorder_rules       ReorderRule[]
  vendor_prices       VendorPriceListEntry[]
  po_lines            PurchaseOrderLine[]
  price_list_entries  PriceListEntry[]
  quote_lines         QuoteLine[]
  so_lines            SalesOrderLine[]
  bom_finished_goods  BillOfMaterials[]
  bom_components      BOMLine[]
  bom_substitutes     BOMLine[]      @relation("SubstituteComponent")
  wo_finished_goods   WorkOrder[]
  standard_costs      ProductStandardCost[]

  @@unique([org_id, sku])
  @@index([org_id])
  @@index([name])
  @@index([org_id, type])
  @@index([deleted_at])
  @@map("products")
}

model ProductVariant {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String    @db.Uuid
  product_id      String    @db.Uuid
  sku             String
  name            String
  attributes      Json      // { "size": "L", "color": "Red" }
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  product         Product   @relation(fields: [product_id], references: [id])
  barcodes        ProductBarcode[]

  @@unique([org_id, sku])
  @@index([product_id])
  @@map("product_variants")
}

model ProductBarcode {
  id              String      @id @default(uuid()) @db.Uuid
  org_id          String      @db.Uuid
  product_id      String      @db.Uuid
  variant_id      String?     @db.Uuid
  barcode         String
  barcode_type    BarcodeType
  is_primary      Boolean     @default(false)
  created_at      DateTime    @default(now()) @db.Timestamptz

  product         Product     @relation(fields: [product_id], references: [id])
  variant         ProductVariant? @relation(fields: [variant_id], references: [id])

  @@unique([org_id, barcode])
  @@index([org_id])
  @@index([barcode])
  @@map("product_barcodes")
}

model ProductImage {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String    @db.Uuid
  product_id      String    @db.Uuid
  storage_key     String    // R2 object key
  url             String    // pre-signed or CDN URL (refreshed)
  sort_order      Int       @default(0)
  is_primary      Boolean   @default(false)
  created_at      DateTime  @default(now()) @db.Timestamptz

  product         Product   @relation(fields: [product_id], references: [id])

  @@index([product_id])
  @@map("product_images")
}

// ============================================================
// INVENTORY LEDGER (Source of Truth)
// ============================================================

model InventoryLedgerEntry {
  id                  String        @id @default(uuid()) @db.Uuid
  org_id              String        @db.Uuid
  product_id          String        @db.Uuid
  warehouse_id        String        @db.Uuid
  bin_location_id     String?       @db.Uuid
  lot_id              String?       @db.Uuid
  serial_number_id    String?       @db.Uuid
  movement_type       MovementType
  quantity            Decimal       @db.Decimal(18, 4) // positive = in, negative = out
  uom_id              String        @db.Uuid   // always stocking UOM
  unit_cost_cents     BigInt        // cost per unit in cents
  total_cost_cents    BigInt        // quantity × unit_cost_cents
  currency_code       String        @default("USD") @db.VarChar(3)
  reference_type      ReferenceType
  reference_id        String        @db.Uuid
  reversal_of_id      String?       @db.Uuid   // set on reversal entries
  notes               String?
  created_by          String        @db.Uuid
  created_at          DateTime      @default(now()) @db.Timestamptz

  org                 Organization     @relation(fields: [org_id], references: [id])
  product             Product          @relation(fields: [product_id], references: [id])
  warehouse           Warehouse        @relation(fields: [warehouse_id], references: [id])
  bin_location        BinLocation?     @relation(fields: [bin_location_id], references: [id])
  lot                 Lot?             @relation(fields: [lot_id], references: [id])
  serial_number       SerialNumber?    @relation(fields: [serial_number_id], references: [id])
  reversal_of         InventoryLedgerEntry? @relation("LedgerReversal", fields: [reversal_of_id], references: [id])
  reversals           InventoryLedgerEntry[] @relation("LedgerReversal")

  @@index([org_id])
  @@index([org_id, product_id])
  @@index([org_id, product_id, warehouse_id])
  @@index([org_id, movement_type])
  @@index([reference_type, reference_id])
  @@index([lot_id])
  @@index([created_at])
  @@map("inventory_ledger_entries")
}

model FifoCostLayer {
  id                  String    @id @default(uuid()) @db.Uuid
  org_id              String    @db.Uuid
  product_id          String    @db.Uuid
  warehouse_id        String    @db.Uuid
  receipt_id          String    @db.Uuid   // the receipt that created this layer
  quantity_received   Decimal   @db.Decimal(18, 4)
  quantity_remaining  Decimal   @db.Decimal(18, 4)
  unit_cost_cents     BigInt
  currency_code       String    @default("USD") @db.VarChar(3)
  received_at         DateTime  @db.Timestamptz
  fully_consumed_at   DateTime? @db.Timestamptz
  created_at          DateTime  @default(now()) @db.Timestamptz

  org                 Organization @relation(fields: [org_id], references: [id])
  product             Product      @relation(fields: [product_id], references: [id])
  warehouse           Warehouse    @relation(fields: [warehouse_id], references: [id])

  @@index([org_id, product_id, warehouse_id, received_at]) // FIFO consumption order
  @@index([org_id, product_id, warehouse_id, quantity_remaining])
  @@map("fifo_cost_layers")
}

model WeightedAverageCost {
  id                  String    @id @default(uuid()) @db.Uuid
  org_id              String    @db.Uuid
  product_id          String    @db.Uuid
  warehouse_id        String    @db.Uuid
  average_cost_cents  BigInt    // current weighted average unit cost
  quantity_on_hand    Decimal   @db.Decimal(18, 4)
  currency_code       String    @default("USD") @db.VarChar(3)
  updated_at          DateTime  @updatedAt @db.Timestamptz

  org                 Organization @relation(fields: [org_id], references: [id])
  product             Product      @relation(fields: [product_id], references: [id])
  warehouse           Warehouse    @relation(fields: [warehouse_id], references: [id])

  @@unique([org_id, product_id, warehouse_id])
  @@index([org_id, product_id])
  @@map("weighted_average_costs")
}

model Lot {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String    @db.Uuid
  product_id      String    @db.Uuid
  lot_number      String
  batch_number    String?
  expires_at      DateTime? @db.Timestamptz
  manufactured_at DateTime? @db.Timestamptz
  is_quarantine   Boolean   @default(false)
  notes           String?
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  org             Organization           @relation(fields: [org_id], references: [id])
  product         Product                @relation(fields: [product_id], references: [id])
  ledger_entries  InventoryLedgerEntry[]
  receipt_lines   ReceiptLine[]
  shipment_lines  ShipmentLine[]

  @@unique([org_id, product_id, lot_number])
  @@index([org_id])
  @@index([org_id, product_id])
  @@index([expires_at])
  @@map("lots")
}

model SerialNumber {
  id              String              @id @default(uuid()) @db.Uuid
  org_id          String              @db.Uuid
  product_id      String              @db.Uuid
  serial_number   String
  status          SerialNumberStatus
  lot_id          String?             @db.Uuid
  created_at      DateTime            @default(now()) @db.Timestamptz
  updated_at      DateTime            @updatedAt @db.Timestamptz
  deleted_at      DateTime?           @db.Timestamptz

  org             Organization           @relation(fields: [org_id], references: [id])
  product         Product                @relation(fields: [product_id], references: [id])
  ledger_entries  InventoryLedgerEntry[]

  @@unique([org_id, product_id, serial_number])
  @@index([org_id, product_id])
  @@map("serial_numbers")
}

model ReorderRule {
  id                  String    @id @default(uuid()) @db.Uuid
  org_id              String    @db.Uuid
  product_id          String    @db.Uuid
  warehouse_id        String    @db.Uuid
  reorder_point       Decimal   @db.Decimal(18, 4) // trigger when stock falls below this
  reorder_quantity    Decimal   @db.Decimal(18, 4) // how much to order
  safety_stock        Decimal   @db.Decimal(18, 4)
  lead_time_days      Int
  preferred_vendor_id String?   @db.Uuid
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz

  org                 Organization @relation(fields: [org_id], references: [id])
  product             Product      @relation(fields: [product_id], references: [id])
  warehouse           Warehouse    @relation(fields: [warehouse_id], references: [id])

  @@unique([org_id, product_id, warehouse_id])
  @@index([org_id])
  @@map("reorder_rules")
}

// ============================================================
// VENDORS & PURCHASING
// ============================================================

model Vendor {
  id                  String    @id @default(uuid()) @db.Uuid
  org_id              String    @db.Uuid
  name                String
  code                String?
  email               String?
  phone               String?
  address_line1       String?
  address_line2       String?
  city                String?
  state               String?   @db.Char(2)
  zip                 String?
  tax_id              String?   // stored encrypted
  payment_terms       PaymentTerms @default(NET30)
  lead_time_days      Int       @default(7)
  currency_code       String    @default("USD") @db.VarChar(3)
  notes               String?
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz
  created_by          String?   @db.Uuid
  updated_by          String?   @db.Uuid
  deleted_at          DateTime? @db.Timestamptz
  deleted_by          String?   @db.Uuid

  org                 Organization          @relation(fields: [org_id], references: [id])
  contacts            VendorContact[]
  price_list          VendorPriceListEntry[]
  purchase_orders     PurchaseOrder[]

  @@index([org_id])
  @@index([name])
  @@map("vendors")
}

model VendorContact {
  id              String    @id @default(uuid()) @db.Uuid
  vendor_id       String    @db.Uuid
  name            String
  role            String?
  email           String?
  phone           String?
  is_primary      Boolean   @default(false)
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  vendor          Vendor    @relation(fields: [vendor_id], references: [id])

  @@index([vendor_id])
  @@map("vendor_contacts")
}

model VendorPriceListEntry {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String    @db.Uuid
  vendor_id       String    @db.Uuid
  product_id      String    @db.Uuid
  unit_cost_cents BigInt
  currency_code   String    @default("USD") @db.VarChar(3)
  min_quantity    Decimal   @db.Decimal(18, 4) @default(1)
  uom_id          String    @db.Uuid
  effective_from  DateTime  @db.Timestamptz
  effective_to    DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  vendor          Vendor    @relation(fields: [vendor_id], references: [id])
  product         Product   @relation(fields: [product_id], references: [id])

  @@index([vendor_id, product_id])
  @@index([org_id])
  @@map("vendor_price_list_entries")
}

model PurchaseOrder {
  id                  String      @id @default(uuid()) @db.Uuid
  org_id              String      @db.Uuid
  po_number           String      // org-scoped sequence e.g. PO-2024-00001
  vendor_id           String      @db.Uuid
  status              POStatus    @default(DRAFT)
  currency_code       String      @default("USD") @db.VarChar(3)
  subtotal_cents      BigInt      @default(0)
  tax_cents           BigInt      @default(0)
  total_cents         BigInt      @default(0)
  payment_terms       PaymentTerms @default(NET30)
  expected_date       DateTime?   @db.Timestamptz
  notes               String?
  internal_notes      String?
  approved_by         String?     @db.Uuid
  approved_at         DateTime?   @db.Timestamptz
  sent_at             DateTime?   @db.Timestamptz
  cancelled_at        DateTime?   @db.Timestamptz
  cancelled_reason    String?
  created_at          DateTime    @default(now()) @db.Timestamptz
  updated_at          DateTime    @updatedAt @db.Timestamptz
  created_by          String?     @db.Uuid
  updated_by          String?     @db.Uuid
