  invoices            Invoice[]
  return_auths        ReturnAuthorization[]

  @@unique([org_id, order_number])
  @@index([org_id])
  @@index([org_id, status])
  @@index([customer_id])
  @@map("sales_orders")
}

model SalesOrderLine {
  id                    String              @id @default(uuid()) @db.Uuid
  org_id                String              @db.Uuid
  so_id                 String              @db.Uuid
  product_id            String              @db.Uuid
  description           String?
  quantity_ordered      Decimal             @db.Decimal(18, 4)
  quantity_fulfilled    Decimal             @db.Decimal(18, 4) @default(0)
  uom_id                String              @db.Uuid
  unit_price_cents      BigInt
  discount_pct          Decimal             @db.Decimal(5, 2) @default(0)
  tax_pct               Decimal             @db.Decimal(5, 2) @default(0)
  tax_cents             BigInt              @default(0)
  total_cents           BigInt
  currency_code         String              @default("USD") @db.VarChar(3)
  fulfillment_status    FulfillmentStatus   @default(UNFULFILLED)
  sort_order            Int                 @default(0)
  created_at            DateTime            @default(now()) @db.Timestamptz
  updated_at            DateTime            @updatedAt @db.Timestamptz

