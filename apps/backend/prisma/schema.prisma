model BillOfMaterials {
  id                  String    @id @default(uuid()) @db.Uuid
  org_id              String    @db.Uuid
  product_id          String    @db.Uuid // finished good
  name                String
  description         String?
  active_version_id   String?   @db.Uuid
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz
  created_by          String?   @db.Uuid
  deleted_at          DateTime? @db.Timestamptz

  org                 Organization  @relation(fields: [org_id], references: [id])
  product             Product       @relation(fields: [product_id], references: [id])
  versions            BOMVersion[]

  @@index([org_id])
  @@index([product_id])
  @@map("bills_of_materials")
}

model BOMVersion {
  id                  String    @id @default(uuid()) @db.Uuid
  bom_id              String    @db.Uuid
  org_id              String    @db.Uuid
  version_number      Int
  is_active           Boolean   @default(false)
  notes               String?
  standard_cost_cents BigInt    @default(0) // calculated from lines
  currency_code       String    @default("USD") @db.VarChar(3)
  activated_at        DateTime? @db.Timestamptz
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz

  bom                 BillOfMaterials @relation(fields: [bom_id], references: [id])
  lines               BOMLine[]
  work_orders         WorkOrder[]
  standard_costs      ProductStandardCost[]

  @@unique([bom_id, version_number])
  @@index([bom_id])
  @@map("bom_versions")
}

model BOMLine {
  id                  String    @id @default(uuid()) @db.Uuid
  bom_version_id      String    @db.Uuid
  org_id              String    @db.Uuid
  component_id        String    @db.Uuid // component product
  quantity            Decimal   @db.Decimal(18, 6)
  uom_id              String    @db.Uuid
  scrap_pct           Decimal   @db.Decimal(5, 2) @default(0)
  substitute_id       String?   @db.Uuid // alternative component
  is_phantom          Boolean   @default(false) // for multi-level BOM sub-assemblies
  notes               String?
  sort_order          Int       @default(0)
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz

  bom_version         BOMVersion @relation(fields: [bom_version_id], references: [id])
  component           Product    @relation(fields: [component_id], references: [id])
  uom                 UnitOfMeasure @relation(fields: [uom_id], references: [id])
  substitute          Product?   @relation("SubstituteComponent", fields: [substitute_id], references: [id])
  wo_material_lines   WorkOrderMaterialLine[]

  @@index([bom_version_id])
  @@index([component_id])
  @@map("bom_lines")
}

model WorkOrder {
  id                    String        @id @default(uuid()) @db.Uuid
  org_id                String        @db.Uuid
  wo_number             String
  product_id            String        @db.Uuid // finished good
  bom_version_id        String        @db.Uuid
  warehouse_id          String        @db.Uuid
  status                WOStatus      @default(DRAFT)
  quantity_planned      Decimal       @db.Decimal(18, 4)
  quantity_produced     Decimal       @db.Decimal(18, 4) @default(0)
  quantity_scrapped     Decimal       @db.Decimal(18, 4) @default(0)
  currency_code         String        @default("USD") @db.VarChar(3)
  planned_cost_cents    BigInt        @default(0) // from BOM standard cost
  actual_cost_cents     BigInt        @default(0) // actual materials + labor
  scheduled_start       DateTime?     @db.Timestamptz
  scheduled_end         DateTime?     @db.Timestamptz
  actual_start          DateTime?     @db.Timestamptz
  actual_end            DateTime?     @db.Timestamptz
  notes                 String?
  qc_passed             Boolean?
  qc_notes              String?
  created_at            DateTime      @default(now()) @db.Timestamptz
  updated_at            DateTime      @updatedAt @db.Timestamptz
  created_by            String?       @db.Uuid
  updated_by            String?       @db.Uuid
  deleted_at            DateTime?     @db.Timestamptz

  org                   Organization  @relation(fields: [org_id], references: [id])
  product               Product       @relation(fields: [product_id], references: [id])
  bom_version           BOMVersion    @relation(fields: [bom_version_id], references: [id])
  material_lines        WorkOrderMaterialLine[]
  labor_entries         WorkOrderLaborEntry[]
  scrap_entries         WorkOrderScrapEntry[]

  @@unique([org_id, wo_number])
  @@index([org_id])
  @@index([org_id, status])
  @@map("work_orders")
}

model WorkOrderMaterialLine {
  id                    String    @id @default(uuid()) @db.Uuid
  wo_id                 String    @db.Uuid
  bom_line_id           String    @db.Uuid
  quantity_planned      Decimal   @db.Decimal(18, 4)
  quantity_consumed     Decimal   @db.Decimal(18, 4) @default(0)
  uom_id                String    @db.Uuid
  lot_id                String?   @db.Uuid
  created_at            DateTime  @default(now()) @db.Timestamptz
  updated_at            DateTime  @updatedAt @db.Timestamptz

  wo                    WorkOrder @relation(fields: [wo_id], references: [id])
  bom_line              BOMLine   @relation(fields: [bom_line_id], references: [id])

  @@index([wo_id])
  @@map("work_order_material_lines")
}

model WorkOrderLaborEntry {
  id              String    @id @default(uuid()) @db.Uuid
  wo_id           String    @db.Uuid
  org_id          String    @db.Uuid
  hours           Decimal   @db.Decimal(8, 2)
  rate_cents      BigInt    // hourly rate in cents
  total_cents     BigInt
  currency_code   String    @default("USD") @db.VarChar(3)
  recorded_by     String    @db.Uuid
  recorded_at     DateTime  @db.Timestamptz
  notes           String?
  created_at      DateTime  @default(now()) @db.Timestamptz

  wo              WorkOrder @relation(fields: [wo_id], references: [id])

  @@index([wo_id])
  @@map("work_order_labor_entries")
}

model WorkOrderScrapEntry {
  id              String    @id @default(uuid()) @db.Uuid
  wo_id           String    @db.Uuid
  org_id          String    @db.Uuid
  quantity        Decimal   @db.Decimal(18, 4)
  reason_code     String
  disposition     ScrapDisposition
  notes           String?
  created_at      DateTime  @default(now()) @db.Timestamptz
  created_by      String    @db.Uuid

  wo              WorkOrder @relation(fields: [wo_id], references: [id])

  @@index([wo_id])
  @@map("work_order_scrap_entries")
}

// ============================================================
// COSTING
// ============================================================

model OverheadAllocationRule {
  id              String              @id @default(uuid()) @db.Uuid
  org_id          String              @unique @db.Uuid
  method          OverheadMethod
  pct_of_material Decimal?            @db.Decimal(5, 2)  // if method = PCT_OF_MATERIAL
  per_unit_cents  BigInt?             // if method = PER_UNIT
  per_hour_cents  BigInt?             // if method = PER_LABOR_HOUR
  currency_code   String              @default("USD") @db.VarChar(3)
  updated_at      DateTime            @updatedAt @db.Timestamptz

  org             Organization        @relation(fields: [org_id], references: [id])

  @@map("overhead_allocation_rules")
}

model ProductStandardCost {
  id                    String    @id @default(uuid()) @db.Uuid
  org_id                String    @db.Uuid
  product_id            String    @db.Uuid
  bom_version_id        String?   @db.Uuid
  material_cost_cents   BigInt    @default(0)
  labor_cost_cents      BigInt    @default(0)
  overhead_cost_cents   BigInt    @default(0)
  total_cost_cents      BigInt    @default(0)
  currency_code         String    @default("USD") @db.VarChar(3)
  effective_from        DateTime  @db.Timestamptz
  effective_to          DateTime? @db.Timestamptz
  created_at            DateTime  @default(now()) @db.Timestamptz

  org                   Organization @relation(fields: [org_id], references: [id])
  product               Product      @relation(fields: [product_id], references: [id])
  bom_version           BOMVersion?  @relation(fields: [bom_version_id], references: [id])

  @@index([org_id, product_id, effective_from])
  @@map("product_standard_costs")
}

// ============================================================
// FINANCIALS
// ============================================================

model TaxSettings {
  id                  String    @id @default(uuid()) @db.Uuid
  org_id              String    @unique @db.Uuid
  collect_sales_tax   Boolean   @default(false)
  nexus_states        String[]  @db.Char(2)
  default_tax_rate    Decimal   @db.Decimal(5, 4) @default(0) // e.g. 0.0825 = 8.25%
  updated_at          DateTime  @updatedAt @db.Timestamptz

  org                 Organization @relation(fields: [org_id], references: [id])

  @@map("tax_settings")
}

model ChartOfAccount {
  id              String          @id @default(uuid()) @db.Uuid
  org_id          String          @db.Uuid
  code            String
  name            String
  type            AccountType
  subtype         String?
  is_system       Boolean         @default(false) // system accounts cannot be deleted
  parent_id       String?         @db.Uuid
  created_at      DateTime        @default(now()) @db.Timestamptz
  updated_at      DateTime        @updatedAt @db.Timestamptz
  deleted_at      DateTime?       @db.Timestamptz

  org             Organization    @relation(fields: [org_id], references: [id])
  parent          ChartOfAccount? @relation("AccountTree", fields: [parent_id], references: [id])
  children        ChartOfAccount[] @relation("AccountTree")
  journal_lines   JournalEntryLine[]

  @@unique([org_id, code])
  @@index([org_id])
  @@map("chart_of_accounts")
}

model JournalEntry {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String    @db.Uuid
  entry_number    String
  date            DateTime  @db.Timestamptz
  description     String
  reference_type  String?
  reference_id    String?   @db.Uuid
  currency_code   String    @default("USD") @db.VarChar(3)
  posted_at       DateTime? @db.Timestamptz
  posted_by       String?   @db.Uuid
  created_at      DateTime  @default(now()) @db.Timestamptz

  org             Organization       @relation(fields: [org_id], references: [id])
  lines           JournalEntryLine[]

  @@unique([org_id, entry_number])
  @@index([org_id])
  @@index([reference_type, reference_id])
  @@map("journal_entries")
}

model JournalEntryLine {
  id              String    @id @default(uuid()) @db.Uuid
  journal_id      String    @db.Uuid
  account_id      String    @db.Uuid
  debit_cents     BigInt    @default(0)
  credit_cents    BigInt    @default(0)
  currency_code   String    @default("USD") @db.VarChar(3)
  description     String?

  journal         JournalEntry   @relation(fields: [journal_id], references: [id])
  account         ChartOfAccount @relation(fields: [account_id], references: [id])

  @@index([journal_id])
  @@map("journal_entry_lines")
}

model ExpenseCategory {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String    @db.Uuid
  name            String
  description     String?
  account_id      String?   @db.Uuid // maps to ChartOfAccount
  is_overhead     Boolean   @default(false)
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  org             Organization @relation(fields: [org_id], references: [id])
  expenses        Expense[]

  @@index([org_id])
  @@map("expense_categories")
}

model Expense {
  id                  String            @id @default(uuid()) @db.Uuid
  org_id              String            @db.Uuid
  category_id         String            @db.Uuid
  description         String
  amount_cents        BigInt
  currency_code       String            @default("USD") @db.VarChar(3)
  expense_date        DateTime          @db.Timestamptz
  recurrence          ExpenseRecurrence @default(ONE_TIME)
  attachment_key      String?           // R2 storage key
  attachment_name     String?           // original filename for display
  is_overhead         Boolean           @default(false)
  notes               String?
  created_at          DateTime          @default(now()) @db.Timestamptz
  updated_at          DateTime          @updatedAt @db.Timestamptz
  created_by          String?           @db.Uuid
  deleted_at          DateTime?         @db.Timestamptz

  org                 Organization      @relation(fields: [org_id], references: [id])
  category            ExpenseCategory   @relation(fields: [category_id], references: [id])

  @@index([org_id])
  @@index([org_id, expense_date])
  @@map("expenses")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id              String              @id @default(uuid()) @db.Uuid
  org_id          String              @db.Uuid
  user_id         String              @db.Uuid
  type            NotificationType
  severity        NotificationSeverity
  title           String
  body            String
  reference_type  String?
  reference_id    String?             @db.Uuid
  is_read         Boolean             @default(false)
  read_at         DateTime?           @db.Timestamptz
  created_at      DateTime            @default(now()) @db.Timestamptz

  org             Organization        @relation(fields: [org_id], references: [id])

  @@index([org_id, user_id, is_read])
  @@index([org_id, user_id, created_at])
  @@map("notifications")
}

model NotificationPreference {
  id                  String              @id @default(uuid()) @db.Uuid
  user_id             String              @db.Uuid
  notification_type   NotificationType
  in_app              Boolean             @default(true)
  email               Boolean             @default(true)
  updated_at          DateTime            @updatedAt @db.Timestamptz

  user                User                @relation(fields: [user_id], references: [id])

  @@unique([user_id, notification_type])
  @@map("notification_preferences")
}

// ============================================================
// IMPORTS & AUDIT
// ============================================================

model ImportBatch {
  id                  String      @id @default(uuid()) @db.Uuid
  org_id              String      @db.Uuid
  entity_type         ImportEntity
  status              ImportStatus @default(PENDING)
  original_filename   String
  storage_key         String      // R2 key for original CSV
  error_report_key    String?     // R2 key for error report CSV
  total_rows          Int         @default(0)
  valid_rows          Int         @default(0)
  error_rows          Int         @default(0)
  imported_rows       Int         @default(0)
  rollback_expires_at DateTime?   @db.Timestamptz
  rolled_back_at      DateTime?   @db.Timestamptz
  created_at          DateTime    @default(now()) @db.Timestamptz
  updated_at          DateTime    @updatedAt @db.Timestamptz
  created_by          String      @db.Uuid

  org                 Organization @relation(fields: [org_id], references: [id])

  @@index([org_id])
  @@map("import_batches")
}

model AuditLog {
  id              String      @id @default(uuid()) @db.Uuid
  org_id          String      @db.Uuid
  user_id         String?     @db.Uuid
  action          AuditAction
  entity_type     String
  entity_id       String      @db.Uuid
  before_state    Json?
  after_state     Json?
  ip_address      String?
  user_agent      String?
  created_at      DateTime    @default(now()) @db.Timestamptz

  org             Organization @relation(fields: [org_id], references: [id])

  @@index([org_id])
  @@index([org_id, entity_type, entity_id])
  @@index([org_id, user_id])
  @@index([created_at])
  @@map("audit_logs")
}

// ============================================================
// DOCUMENT SEQUENCES
// ============================================================

model DocumentSequence {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String    @db.Uuid
  document_type   String    // PO, SO, QUOTE, INVOICE, WO, RMA, RECEIPT, CREDIT_MEMO
  prefix          String    // e.g. "INV-", "PO-"
  next_number     Int       @default(1)
  zero_pad_length Int       @default(5)
  updated_at      DateTime  @updatedAt @db.Timestamptz

  @@unique([org_id, document_type])
  @@index([org_id])
  @@map("document_sequences")
}

