  @@index([so_id])
  @@index([org_id])
  @@map("sales_order_lines")
}

model Shipment {
  id                  String    @id @default(uuid()) @db.Uuid
  org_id              String    @db.Uuid
  shipment_number     String
  so_id               String    @db.Uuid
  warehouse_id        String    @db.Uuid
  carrier             String?
  tracking_number     String?
  shipping_cost_cents BigInt    @default(0)
  currency_code       String    @default("USD") @db.VarChar(3)
  shipped_at          DateTime? @db.Timestamptz
  notes               String?
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz
  created_by          String?   @db.Uuid
  deleted_at          DateTime? @db.Timestamptz

  so                  SalesOrder @relation(fields: [so_id], references: [id])
  lines               ShipmentLine[]

  @@unique([org_id, shipment_number])
  @@index([so_id])
  @@index([org_id])
  @@map("shipments")
}

model ShipmentLine {
  id              String    @id @default(uuid()) @db.Uuid
  shipment_id     String    @db.Uuid
  so_line_id      String    @db.Uuid
  quantity        Decimal   @db.Decimal(18, 4)
  lot_id          String?   @db.Uuid
  serial_number_id String?  @db.Uuid
  bin_location_id String?   @db.Uuid
  created_at      DateTime  @default(now()) @db.Timestamptz

  shipment        Shipment      @relation(fields: [shipment_id], references: [id])
  so_line         SalesOrderLine @relation(fields: [so_line_id], references: [id])
  lot             Lot?          @relation(fields: [lot_id], references: [id])

  @@index([shipment_id])
  @@map("shipment_lines")
}

model Invoice {
  id                    String          @id @default(uuid()) @db.Uuid
  org_id                String          @db.Uuid
  invoice_number        String
  customer_id           String          @db.Uuid
  so_id                 String?         @db.Uuid
  status                InvoiceStatus   @default(DRAFT)
  currency_code         String          @default("USD") @db.VarChar(3)
  subtotal_cents        BigInt          @default(0)
  discount_cents        BigInt          @default(0)
  tax_cents             BigInt          @default(0)
  shipping_cents        BigInt          @default(0)
  total_cents           BigInt          @default(0)
  amount_paid_cents     BigInt          @default(0)
  amount_due_cents      BigInt          @default(0)
  payment_terms         PaymentTerms    @default(NET30)
  due_date              DateTime?       @db.Timestamptz
  stripe_payment_link   String?
  stripe_invoice_id     String?
  sent_at               DateTime?       @db.Timestamptz
  paid_at               DateTime?       @db.Timestamptz
  voided_at             DateTime?       @db.Timestamptz
  voided_reason         String?
  notes                 String?
  created_at            DateTime        @default(now()) @db.Timestamptz
  updated_at            DateTime        @updatedAt @db.Timestamptz
  created_by            String?         @db.Uuid
  updated_by            String?         @db.Uuid
  deleted_at            DateTime?       @db.Timestamptz
  deleted_by            String?         @db.Uuid

  org                   Organization    @relation(fields: [org_id], references: [id])
  customer              Customer        @relation(fields: [customer_id], references: [id])
  so                    SalesOrder?     @relation(fields: [so_id], references: [id])
  lines                 InvoiceLine[]
  payments              Payment[]
  credit_memos          CreditMemo[]

  @@unique([org_id, invoice_number])
  @@index([org_id])
  @@index([org_id, status])
  @@index([customer_id])
  @@index([due_date])
  @@map("invoices")
}

model InvoiceLine {
  id                  String    @id @default(uuid()) @db.Uuid
  invoice_id          String    @db.Uuid
  so_line_id          String?   @db.Uuid
  product_id          String?   @db.Uuid
  description         String
  quantity            Decimal   @db.Decimal(18, 4)
  unit_price_cents    BigInt
  discount_pct        Decimal   @db.Decimal(5, 2) @default(0)
  tax_pct             Decimal   @db.Decimal(5, 2) @default(0)
  tax_cents           BigInt    @default(0)
  total_cents         BigInt
  unit_cost_cents     BigInt    @default(0) // COGS at time of sale
  currency_code       String    @default("USD") @db.VarChar(3)
  sort_order          Int       @default(0)
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz

  invoice             Invoice   @relation(fields: [invoice_id], references: [id])
  so_line             SalesOrderLine? @relation(fields: [so_line_id], references: [id])

  @@index([invoice_id])
  @@map("invoice_lines")
}

model Payment {
  id                  String        @id @default(uuid()) @db.Uuid
  org_id              String        @db.Uuid
  invoice_id          String        @db.Uuid
  amount_cents        BigInt
  currency_code       String        @default("USD") @db.VarChar(3)
  method              PaymentMethod
  reference           String?       // check number, ACH ref, Stripe charge ID
  stripe_payment_id   String?       @unique
  paid_at             DateTime      @db.Timestamptz
  notes               String?
  created_at          DateTime      @default(now()) @db.Timestamptz
  created_by          String?       @db.Uuid
  deleted_at          DateTime?     @db.Timestamptz

  invoice             Invoice       @relation(fields: [invoice_id], references: [id])

  @@index([invoice_id])
  @@index([org_id])
  @@map("payments")
}

model CreditMemo {
  id                  String    @id @default(uuid()) @db.Uuid
  org_id              String    @db.Uuid
  memo_number         String
  invoice_id          String?   @db.Uuid
  customer_id         String    @db.Uuid
  amount_cents        BigInt
  currency_code       String    @default("USD") @db.VarChar(3)
  reason              String?
  applied_at          DateTime? @db.Timestamptz
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz
  created_by          String?   @db.Uuid
  deleted_at          DateTime? @db.Timestamptz

  invoice             Invoice?  @relation(fields: [invoice_id], references: [id])

  @@unique([org_id, memo_number])
  @@index([org_id])
  @@map("credit_memos")
}

model ReturnAuthorization {
  id                  String      @id @default(uuid()) @db.Uuid
  org_id              String      @db.Uuid
  rma_number          String
  so_id               String      @db.Uuid
  customer_id         String      @db.Uuid
  status              RMAStatus   @default(PENDING)
  reason              String?
  notes               String?
  received_at         DateTime?   @db.Timestamptz
  created_at          DateTime    @default(now()) @db.Timestamptz
  updated_at          DateTime    @updatedAt @db.Timestamptz
  created_by          String?     @db.Uuid
  deleted_at          DateTime?   @db.Timestamptz

  org                 Organization @relation(fields: [org_id], references: [id])
  so                  SalesOrder   @relation(fields: [so_id], references: [id])
  customer            Customer     @relation(fields: [customer_id], references: [id])
  lines               ReturnLine[]

  @@unique([org_id, rma_number])
  @@index([org_id])
  @@map("return_authorizations")
}

model ReturnLine {
  id                  String              @id @default(uuid()) @db.Uuid
  rma_id              String              @db.Uuid
  so_line_id          String              @db.Uuid
  quantity            Decimal             @db.Decimal(18, 4)
  condition           ReturnCondition
  disposition         ReturnDisposition
  restock_warehouse_id String?            @db.Uuid
  notes               String?
  created_at          DateTime            @default(now()) @db.Timestamptz

  rma                 ReturnAuthorization @relation(fields: [rma_id], references: [id])
  so_line             SalesOrderLine      @relation(fields: [so_line_id], references: [id])

