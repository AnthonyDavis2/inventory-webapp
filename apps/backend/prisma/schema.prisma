model CustomerGroup {
  id              String    @id @default(uuid()) @db.Uuid
  org_id          String    @db.Uuid
  name            String
  description     String?
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz
  deleted_at      DateTime? @db.Timestamptz

  org             Organization @relation(fields: [org_id], references: [id])
  customers       Customer[]

  @@index([org_id])
  @@map("customer_groups")
}

model Customer {
  id                    String        @id @default(uuid()) @db.Uuid
  org_id                String        @db.Uuid
  name                  String
  code                  String?
  type                  CustomerType
  group_id              String?       @db.Uuid
  price_list_id         String?       @db.Uuid
  payment_terms         PaymentTerms  @default(NET30)
  credit_limit_cents    BigInt        @default(0)
  currency_code         String        @default("USD") @db.VarChar(3)
  tax_exempt            Boolean       @default(false)
  tax_exempt_number     String?
  tax_exempt_expires    DateTime?     @db.Timestamptz
  notes                 String?
  created_at            DateTime      @default(now()) @db.Timestamptz
  updated_at            DateTime      @updatedAt @db.Timestamptz
  created_by            String?       @db.Uuid
  updated_by            String?       @db.Uuid
  deleted_at            DateTime?     @db.Timestamptz
  deleted_by            String?       @db.Uuid

  org                   Organization  @relation(fields: [org_id], references: [id])
